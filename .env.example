# ─── Supabase ───────────────────────────────────────────────────────────────
# 1. Acesse https://supabase.com e abra o projeto
# 2. Vá em Settings → API e copie os valores abaixo
# 3. Renomeie este arquivo para .env (ou crie .env.local)
# 4. No Vercel: Settings → Environment Variables → adicione as mesmas variáveis

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Necessário apenas para a Edge Function de gestão de usuários (api/admin-users.js)
# Nunca commitar este valor — adicionar apenas no Vercel e no .env local
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Chave da API da Anthropic — usada pelo servidor para gerar IA (nunca exposta ao cliente)
# Local (vercel dev): adicionar aqui; Produção: Vercel Dashboard → Settings → Environment Variables
ANTHROPIC_API_KEY=sk-ant-...
